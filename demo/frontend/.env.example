# Production frontend env. Vite reads these at BUILD time, not runtime.
#
# In dev, leave VITE_API_BASE unset — the Vite proxy in vite.config.ts
# routes /api/* to the local runner on port 8001.
#
# In production, point this at the public runner URL. Example:
#   VITE_API_BASE=https://tap-runner.onrender.com
#
# The trailing slash is stripped automatically.

VITE_API_BASE=
