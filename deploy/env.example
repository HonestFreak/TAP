# Shared environment for both TAP demo services on EC2.
# Copy to /home/tap/.tap.env, chmod 0600, then `systemctl daemon-reload`.
#
# Both producer.py and runner.py read this file via systemd's
# `EnvironmentFile=`. Each service ignores keys it doesn't use, so a
# single env is operationally simpler than splitting them.

# ---------------------------------------------------------------------------
# Producer-only
# ---------------------------------------------------------------------------

# Required: your Gemini API key.
GEMINI_API_KEY=

# Filesystem path to the producer's funded devnet keypair JSON.
# (You already have this — drop it at /home/tap/keys/producer.json.)
TAP_PRODUCER_KEYPAIR=/home/tap/keys/producer.json

# Public URL the producer advertises in its 402 responses (x402 metadata).
# This is what an external x402 client would dial; the runner on this box
# uses 127.0.0.1 directly, so the URL is informational here but must still
# match where the producer is actually reachable from the public internet.
TAP_PUBLIC_URL=https://producer.tap.your-domain.com

# ---------------------------------------------------------------------------
# Runner-only
# ---------------------------------------------------------------------------

# Filesystem path to the consumer's funded devnet keypair JSON.
TAP_CONSUMER_KEYPAIR=/home/tap/keys/consumer.json

# Producer's wallet pubkey (run `solana-keygen pubkey producer.json`).
TAP_PRODUCER_PUBKEY=

# How the runner reaches the producer. Same box → loopback is correct.
TAP_PRODUCER_URL=http://127.0.0.1:8000/v1/messages

# Hosted-demo gate. Pick something memorable; put it in the submission form.
TAP_ACCESS_CODE=tap-frontier-2026

# Where the frontend lives. No trailing slash, no path. Multiple origins
# can be comma-separated.
TAP_CORS_ORIGIN=https://your-vercel-app.vercel.app

# Server-side ceiling on per-session deposit (micro-USDC). Defense in
# depth — even if the gate ever leaks, no single request can drain the
# shared devnet wallet beyond this.
TAP_MAX_DEPOSIT_MICRO=200000

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------

# Producer's USDC ATA on devnet (same address read by both services).
TAP_PRODUCER_USDC=

# Use Helius / Triton devnet endpoint for any real demo traffic. The
# public RPC will rate-limit you. (Free tiers exist on both — both are
# Frontier sponsors.)
TAP_RPC=https://api.devnet.solana.com

TAP_NETWORK=solana-devnet
